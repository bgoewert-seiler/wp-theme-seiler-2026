# WordPress Environment
.wp-env.home.json
.wp-env.override.json

# Node modules
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak
*.log

# Local testing artifacts (screenshots, debug files)
.local/

# Playwright test results (configured to use .local/playwright/)
test-results/
playwright-report/

# Playwright MCP snapshots and screenshots
.playwright-mcp/
/*.png

# Claude Code agent data
.claude/

# Build artifacts (root build dir only, src/build is part of the theme)
/build/
dist/
blocks/**/index.asset.php

# PHP dependencies (generated by composer install; seiler-build --zip
# regenerates these at build time, so they don't belong in git)
src/vendor/
vendor-dev/

# Package manager lock files
package-lock.json
yarn.lock
# bun.lock is tracked (Bun is the primary package manager)
