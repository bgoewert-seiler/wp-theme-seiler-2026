{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"custom": true,
			"customDuotone": true,
			"customGradient": true,
			"defaultGradients": false,
			"defaultPalette": false,
			"link": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#0475BC",
					"name": "Seiler Corp Blue"
				},
				{
					"slug": "secondary",
					"color": "#002F63",
					"name": "Seiler Corp Dark Blue"
				},
				{
					"slug": "accent",
					"color": "#FDBA4D",
					"name": "Seiler Geo Yellow"
				},
				{
					"slug": "light-gray",
					"color": "#EFEFEF",
					"name": "Light Gray"
				},
				{
					"slug": "medium-gray",
					"color": "#666666",
					"name": "Medium Gray"
				},
				{
					"slug": "dark-gray",
					"color": "#707070",
					"name": "Dark Gray"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			],
			"gradients": [
				{
					"slug": "primary-to-accent",
					"gradient": "linear-gradient(135deg, #0475BC 0%, #FDBA4D 100%)",
					"name": "Seiler Blue to Yellow"
				},
				{
					"slug": "primary-to-secondary",
					"gradient": "linear-gradient(135deg, #0475BC 0%, #002F63 100%)",
					"name": "Seiler Blue Gradient"
				},
				{
					"slug": "dark-overlay",
					"gradient": "linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%)",
					"name": "Dark Overlay"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"spacing": {
			"units": ["px", "em", "rem", "vh", "vw", "%"],
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"size": "0.5em",
					"slug": "x-small",
					"name": "Extra Small"
				},
				{
					"size": "1em",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "2em",
					"slug": "medium",
					"name": "Medium"
				},
				{
					"size": "3em",
					"slug": "large",
					"name": "Large"
				},
				{
					"size": "4em",
					"slug": "x-large",
					"name": "Extra Large"
				},
				{
					"size": "6em",
					"slug": "2x-large",
					"name": "2X Large"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"fontStyle": true,
			"fontWeight": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textDecoration": true,
			"textTransform": true,
			"dropCap": false,
			"fluid": true,
			"fontSizes": [
				{
					"slug": "small",
					"size": "14px",
					"name": "Small",
					"fluid": false
				},
				{
					"slug": "base",
					"size": "18px",
					"name": "Base",
					"fluid": false
				},
				{
					"slug": "medium",
					"size": "14px",
					"name": "Medium",
					"fluid": {
						"min": "13px",
						"max": "14px"
					}
				},
				{
					"slug": "large",
					"size": "18px",
					"name": "Large",
					"fluid": {
						"min": "16px",
						"max": "18px"
					}
				},
				{
					"slug": "x-large",
					"size": "24px",
					"name": "Extra Large",
					"fluid": {
						"min": "20px",
						"max": "24px"
					}
				},
				{
					"slug": "2x-large",
					"size": "32px",
					"name": "2X Large",
					"fluid": {
						"min": "28px",
						"max": "32px"
					}
				},
				{
					"slug": "3x-large",
					"size": "48px",
					"name": "3X Large",
					"fluid": {
						"min": "36px",
						"max": "48px"
					}
				}
			],
			"fontFamilies": [
				{
					"fontFamily": "\"Source Sans 3\", \"Source Sans Pro\", \"Open Sans\", sans-serif",
					"slug": "seiler-body",
					"name": "Seiler Body (Source Sans)"
				},
				{
					"fontFamily": "\"Exo 2\", \"Source Sans 3\", \"Source Sans Pro\", \"Open Sans\", sans-serif",
					"slug": "seiler-heading",
					"name": "Seiler Heading (Exo 2)"
				},
				{
					"fontFamily": "'Open Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif",
					"slug": "open-sans",
					"name": "Open Sans"
				},
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"slug": "system",
					"name": "System Font"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"slug": "small",
					"shadow": "0 2px 8px rgba(0, 0, 0, 0.1)",
					"name": "Small Shadow"
				},
				{
					"slug": "medium",
					"shadow": "0 4px 16px rgba(0, 0, 0, 0.15)",
					"name": "Medium Shadow"
				},
				{
					"slug": "large",
					"shadow": "0 8px 24px rgba(0, 0, 0, 0.2)",
					"name": "Large Shadow"
				}
			]
		},
		"custom": {
			"fontSizeOriginal": {
				"small": "14px",
				"base": "18px",
				"medium": "18px",
				"large": "24px",
				"xLarge": "32px",
				"twoXLarge": "48px",
				"threeXLarge": "60px"
			},
			"spacing": {
				"gutter": "2em"
			},
			"borderRadius": {
				"small": "4px",
				"medium": "8px",
				"large": "12px"
			},
			"transitions": {
				"fast": "0.2s",
				"medium": "0.3s",
				"slow": "0.5s"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--secondary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--seiler-body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.7",
			"fontWeight": "400"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			},
			"blockGap": "var(--wp--preset--spacing--small)"
		},
		"elements": {
			"p": {
				"typography": {
					"fontWeight": "600"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--small)"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"h1": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--3-x-large)",
					"lineHeight": "1.2",
					"fontWeight": "900",
					"textTransform": "uppercase"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "1em"
					}
				}
			},
			"h2": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--2-x-large)",
					"lineHeight": "1.2",
					"fontWeight": "900",
					"textTransform": "uppercase"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "1em"
					}
				}
			},
			"h3": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.3",
					"fontWeight": "900",
					"textTransform": "uppercase"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "var(--wp--preset--spacing--small)"
					}
				}
			},
			"h4": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.4",
					"fontWeight": "900"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "var(--wp--preset--spacing--small)"
					}
				}
			},
			"h5": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.4",
					"fontWeight": "900"
				}
			},
			"h6": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"lineHeight": "1.4",
					"fontWeight": "900"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--seiler-heading)",
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "800",
					"textTransform": "uppercase",
					"textDecoration": "none",
					"letterSpacing": "0.05em"
				},
				"spacing": {
					"padding": {
						"top": "0.375em",
						"right": "1.75em",
						"bottom": "0.375em",
						"left": "1.75em"
					}
				},
				"border": {
					"radius": "50px"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--secondary)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/button": {
				"variations": {
					"accent": {
						"color": {
							"background": "var(--wp--preset--color--accent)",
							"text": "var(--wp--preset--color--white)"
						},
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--secondary)",
								"text": "var(--wp--preset--color--white)"
							}
						}
					},
					"alternate": {
						"color": {
							"background": "var(--wp--preset--color--primary)",
							"text": "var(--wp--preset--color--white)"
						},
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--secondary)",
								"text": "var(--wp--preset--color--white)"
							}
						}
					},
					"on-dark": {
						"color": {
							"background": "var(--wp--preset--color--white)",
							"text": "var(--wp--preset--color--secondary)"
						},
						":hover": {
							"color": {
								"background": "var(--wp--preset--color--secondary)",
								"text": "var(--wp--preset--color--white)"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--base)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2-x-large)",
					"lineHeight": "1.2",
					"fontWeight": "700"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"style": "solid",
					"width": "0 0 0 4px"
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--medium)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "italic"
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var(--wp--preset--color--primary)",
					"style": "solid",
					"width": "4px 0"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--medium)",
						"bottom": "var(--wp--preset--spacing--small)"
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--light-gray)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "blank",
			"title": "Blank",
			"postTypes": ["page", "post"]
		},
		{
			"name": "full-width",
			"title": "Full Width",
			"postTypes": ["page"]
		},
		{
			"name": "page-feature",
			"title": "Feature Page",
			"postTypes": ["page"]
		}
	]
}
